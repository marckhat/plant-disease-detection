# Python / PyTorch CV project .gitignore

# ---- datasets & artifacts ----
/data/
results/
*.pt
*.pth
*.ckpt
*.onnx

# ---- notebooks checkpoints ----
**/.ipynb_checkpoints/

# ---- python cache ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/

# ---- logs / runs ----
runs/
logs/
*.log

# ---- virtual environments ----
.venv/
venv/
env/
ENV/

# ---- tooling / IDE ----
.idea/
.vscode/

# ---- OS files ----
Thumbs.db
Desktop.ini
.DS_Store

